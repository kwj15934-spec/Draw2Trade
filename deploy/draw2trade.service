[Unit]
Description=Draw2Trade FastAPI Server
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/srv/draw2trade
ExecStart=/srv/draw2trade/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

# 환경변수 파일 경로 (서버에서 직접 편집)
EnvironmentFile=/srv/draw2trade/.env

# 로그
StandardOutput=append:/srv/draw2trade/logs/app.log
StandardError=append:/srv/draw2trade/logs/error.log

[Install]
WantedBy=multi-user.target
