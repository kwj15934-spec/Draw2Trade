# ── Firebase Admin (서버) ─────────────────────────────────────────────────────
# 서비스 계정 키 파일 경로 (secrets/ 폴더에 넣고 .gitignore로 보호)
FIREBASE_SERVICE_ACCOUNT_JSON=secrets/firebase_service_account.json

# 세션 쿠키 서명 비밀키 (충분히 길고 랜덤하게 설정)
SESSION_SECRET=draw2trade_super_secret_key

# ── Firebase 클라이언트 (공개 설정 — 노출해도 안전) ───────────────────────────
# Firebase 콘솔 → 프로젝트 설정 → 내 앱 → 웹 앱 구성에서 복사
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ── 한국투자증권 (KIS) Open API ───────────────────────────────────────────────
# https://apiportal.koreainvestment.com 에서 발급
# 설정 시 KR/US 주가 데이터를 KIS API로 수신 (미설정 시 pykrx/yfinance fallback)
KIS_APP_KEY=
KIS_APP_SECRET=
# KIS_MODE: real (실전투자) | mock (모의투자) — 기본값 real
KIS_MODE=real

# ── Anthropic Claude API (AI 재무 분석 요약) ─────────────────────────────────
# https://console.anthropic.com 에서 발급
# 미설정 시 AI 요약 없이 재무 수치만 반환 (서비스 중단 없음)
ANTHROPIC_API_KEY=

# ── 금융감독원 Open DART API ──────────────────────────────────────────────────
# https://opendart.fss.or.kr 에서 발급 (무료)
# 미설정 시 DART 관련 엔드포인트(/api/v1/dart/*)가 503을 반환
DART_API_KEY=
