# ── Firebase Admin (서버) ─────────────────────────────────────────────────────
# 서비스 계정 키 파일 경로 (secrets/ 폴더에 넣고 .gitignore로 보호)
FIREBASE_SERVICE_ACCOUNT_JSON=secrets/firebase_service_account.json

# 세션 쿠키 서명 비밀키 (충분히 길고 랜덤하게 설정)
SESSION_SECRET=draw2trade_super_secret_key

# ── Firebase 클라이언트 (공개 설정 — 노출해도 안전) ───────────────────────────
# Firebase 콘솔 → 프로젝트 설정 → 내 앱 → 웹 앱 구성에서 복사
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
